<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#333333">

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Back"
        app:fabSize="mini"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/ic_menu_revert"
        app:tint="#FFFFFF"
        app:backgroundTint="#444444" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/canvasContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnBack">

        <com.example.lab_6.DrawingView
            android:id="@+id/drawingView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Brush Size"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.slider.Slider
                android:id="@+id/brushSizeSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="20"
                android:valueFrom="1"
                android:valueTo="200"
                app:thumbColor="?attr/colorPrimary"
                app:trackColorActive="?attr/colorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Opacity (Alpha)"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.slider.Slider
                android:id="@+id/alphaSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="255"
                android:valueFrom="0"
                android:valueTo="255"
                app:thumbColor="?attr/colorSecondary"
                app:trackColorActive="?attr/colorSecondary" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnUndo"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Undo"
                        android:src="@android:drawable/ic_menu_revert"
                        app:tint="#FF5252" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="8dp"
                        android:background="#DDDDDD" />

                    <ImageButton
                        android:id="@+id/btnBrush"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Brush"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="?attr/colorOnSurface" />

                    <ImageButton
                        android:id="@+id/btnEraser"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Eraser"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="?attr/colorOnSurface" />

                    <ImageButton
                        android:id="@+id/btnFill"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Fill"
                        android:src="@drawable/ic_paint_bucket"
                        app:tint="?attr/colorOnSurface" />

                    <ImageButton
                        android:id="@+id/btnText"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Text"
                        android:src="@android:drawable/ic_menu_sort_alphabetically"
                        app:tint="?attr/colorOnSurface" />

                    <ImageButton
                        android:id="@+id/btnImage"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Image"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="?attr/colorOnSurface" />

                    <ImageButton
                        android:id="@+id/btnPickColor"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Color"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="?attr/colorOnSurface" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="8dp"
                        android:background="#DDDDDD" />

                    <ImageButton
                        android:id="@+id/btnAddLayer"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Add Layer"
                        android:src="@android:drawable/ic_input_add"
                        app:tint="?attr/colorOnSurface" />

                    <ImageButton
                        android:id="@+id/btnShowLayers"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Layers"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="?attr/colorOnSurface" />

                    <ImageButton
                        android:id="@+id/btnSave"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Save"
                        android:src="@android:drawable/ic_menu_save"
                        app:tint="?attr/colorOnSurface" />

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layersPanel"
        android:layout_width="200dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="8dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:text="Layers"
                android:textColor="?attr/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLayers"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:overScrollMode="never" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Hold to reorder"
                android:textSize="10sp"
                android:textColor="#888888" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>