<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ArtPro Studio"
            android:textSize="36sp"
            android:fontFamily="sans-serif-black"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="8dp"
            android:textColor="?attr/colorPrimary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Professional Layered Drawing"
            android:layout_gravity="center"
            android:layout_marginBottom="40dp"
            android:alpha="0.7"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/settingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            style="@style/Widget.Material3.CardView.Elevated">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Settings"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="20dp"
                    android:textColor="?attr/colorPrimary"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchDarkTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dark Interface"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnSurface" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOutlineVariant"
                    android:layout_marginVertical="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tools Panel Position"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:textColor="?attr/colorOnSurface"/>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/togglePanelPosition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@+id/btnPosBottom">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPosTop"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="TOP" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPosBottom"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="BOTTOM" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShowCreateDialog"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="CREATE NEW PROJECT"
            android:layout_marginTop="32dp"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="RECENT PROJECTS"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearHistory"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textSize="12sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecentHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:listitem="@android:layout/simple_list_item_2"
            tools:itemCount="3"/>

        <TextView
            android:id="@+id/tvEmptyHistory"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="center"
            android:text="No projects yet. Start drawing!"
            android:alpha="0.4"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Version 1.0.4 | Lab Work 6"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="20dp"
            android:alpha="0.5"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurface"/>

    </LinearLayout>
</ScrollView>